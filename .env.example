PORT=
DATABASE_URL=
NODE_ENV=development
# Frontend origin (used for CORS + auth trusted origins), e.g. http://localhost:5173
APP_CLIENT_URL=

# --- Better Auth (required) ---
# Secret used to sign sessions/tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of THIS backend. Better Auth uses it as the OAuth base URL.
# Must be set to avoid Google "redirect_uri_mismatch". e.g. http://localhost:8787
BETTER_AUTH_URL=

AMADEUS_BASE_URL=
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# --- Google OAuth (Better Auth social provider) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_EMAIL=
BIGDATACLOUD_API_KEY=
OPEN_EXCHANGE_API_KEY=
INTERNAL_API_KEY=
